    <string name="settings_about_title">About EmuCoreV</string>
    <string name="settings_about_body">EmuCoreV is a PS Vita emulator for Android built on the open-source Vita3K project.</string>
    <string name="settings_help_content_description">Open setting help</string>
    <string name="settings_help_pstv_mode">Enables PlayStation TV mode for games that expect it.</string>
    <string name="settings_help_performance_overlay">Shows FPS and performance stats on top of the game.</string>
    <string name="settings_help_performance_overlay_detail">Sets how much data is shown in the performance overlay.</string>
    <string name="settings_help_performance_overlay_position">Sets where the performance overlay appears on screen.</string>
    <string name="settings_help_stretch_display">Fills more of the screen, but may stretch the image.</string>
    <string name="settings_help_fps_hack">Removes the normal frame limit in some games. It can improve speed, but it may break timing.</string>
    <string name="settings_help_vsync">Reduces screen tearing, but may lower performance in some games.</string>
    <string name="settings_help_high_accuracy">Can fix graphics issues, but usually reduces performance.</string>
    <string name="settings_help_resolution">Higher values make the image sharper, but use more GPU power.</string>
    <string name="settings_help_renderer">Vulkan is usually the best choice. OpenGL can help on devices with weak Vulkan support.</string>
    <string name="settings_help_screen_filter">Bilinear smooths the image. Nearest keeps sharper edges.</string>
    <string name="settings_help_anisotropic">Improves texture clarity at angles, but can cost performance.</string>
    <string name="settings_help_texture_cache">Keeps textures in cache to reduce repeated work.</string>
    <string name="settings_help_async_pipeline">Compiles graphics pipelines in the background to reduce stutter.</string>
    <string name="settings_help_shader_compilation_notice">Shows when new shaders are compiling.</string>
    <string name="settings_help_shader_caching_warn">Shows a message in the corner during the initial shader caching phase at game startup.</string>
    <string name="settings_help_disable_surface_sync">Can improve speed on some devices, but may cause instability.</string>
    <string name="settings_help_gamepad_overlay">Shows on-screen controls when you are not using a physical controller.</string>
    <string name="settings_help_touchpad_cursor">Shows the touch cursor for games that use front or rear touch input.</string>
    <string name="settings_help_overlay_scale">Changes the size of the on-screen controls.</string>
    <string name="settings_help_overlay_opacity">Changes how transparent the on-screen controls are.</string>
    <string name="settings_help_disable_motion">Turns off motion controls from your device.</string>
    <string name="settings_help_analog_multiplier">Changes analog stick sensitivity.</string>
    <string name="settings_help_audio_backend">Switches the audio output engine.</string>
    <string name="settings_help_audio_volume">Adjusts emulator audio volume.</string>
    <string name="settings_help_ngs_enable">Keeps Vita NGS audio enabled for normal game audio.</string>
