    <string name="settings_storage_title">Almacenamiento</string>
    <string name="settings_storage_body">Los datos del emulador se guardan en el directorio de archivos de la app en `vita/`. Los juegos instalados en `ux0/app`, la caché de shaders en `cache` y los parches en `patch`.</string>
    <string name="settings_about_title">Sobre EmuCoreV</string>
    <string name="settings_about_body">EmuCoreV es un emulador de PS Vita para Android basado en el proyecto de código abierto Vita3K.</string>
    <string name="settings_help_content_description">Abrir ayuda del ajuste</string>
    <string name="settings_help_pstv_mode">Habilita el modo PlayStation TV para los juegos que lo requieren.</string>
    <string name="settings_help_performance_overlay">Muestra los FPS y estadísticas de rendimiento sobre el juego.</string>
    <string name="settings_help_performance_overlay_detail">Establece cuántos datos se muestran en la superposición de rendimiento.</string>
    <string name="settings_help_performance_overlay_position">Establece dónde aparece la superposición de rendimiento en la pantalla.</string>
    <string name="settings_help_stretch_display">Llena una mayor parte de la pantalla, pero puede estirar la imagen.</string>
    <string name="settings_help_fps_hack">Elimina el límite de fotogramas normal en algunos juegos. Puede mejorar la velocidad, pero podría romper la sincronización.</string>
    <string name="settings_help_vsync">Reduce el desgarro de pantalla (tearing), pero puede disminuir el rendimiento en algunos juegos.</string>
    <string name="settings_help_high_accuracy">Puede arreglar problemas gráficos, pero normalmente reduce el rendimiento.</string>
    <string name="settings_help_resolution">Los valores altos hacen la imagen más nítida, pero usan más potencia de la GPU.</string>
    <string name="settings_help_renderer">Vulkan suele ser la mejor opción. OpenGL puede ayudar en dispositivos con soporte débil de Vulkan.</string>
    <string name="settings_help_screen_filter">Bilineal suaviza la imagen. Más cercano (Nearest) mantiene bordes más nítidos.</string>
    <string name="settings_help_anisotropic">Mejora la claridad de las texturas en ángulos, pero puede costar rendimiento.</string>
    <string name="settings_help_texture_cache">Mantiene las texturas en caché para reducir el trabajo repetido.</string>
    <string name="settings_help_async_pipeline">Compila las canalizaciones gráficas en segundo plano para reducir los tirones.</string>
    <string name="settings_help_shader_compilation_notice">Muestra cuándo se están compilando nuevos shaders.</string>
    <string name="settings_help_shader_caching_warn">Muestra un mensaje en la esquina durante la fase inicial de caché de shaders al iniciar el juego.</string>
    <string name="settings_help_disable_surface_sync">Puede mejorar la velocidad en algunos dispositivos, pero puede causar inestabilidad.</string>
    <string name="settings_help_gamepad_overlay">Muestra controles en pantalla cuando no usas un mando físico.</string>
    <string name="settings_help_touchpad_cursor">Muestra el cursor táctil para juegos que usan la entrada táctil frontal o trasera.</string>
    <string name="settings_help_overlay_scale">Cambia el tamaño de los controles en pantalla.</string>
    <string name="settings_help_overlay_opacity">Cambia lo transparentes que son los controles en pantalla.</string>
    <string name="settings_help_disable_motion">Desactiva los controles de movimiento de tu dispositivo.</string>
    <string name="settings_help_analog_multiplier">Cambia la sensibilidad del stick analógico.</string>
    <string name="settings_help_audio_backend">Cambia el motor de salida de audio.</string>
    <string name="settings_help_audio_volume">Ajusta el volumen de audio del emulador.</string>
    <string name="settings_help_ngs_enable">Mantiene habilitado el audio NGS de Vita para el audio normal del juego.</string>
    <string name="settings_help_packages_folder">Elige la carpeta utilizada para los archivos de paquetes locales de Vita.</string>
