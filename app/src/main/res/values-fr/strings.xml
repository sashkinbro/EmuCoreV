    <string name="settings_storage_body">Les données de l\'émulateur sont stockées dans le répertoire des fichiers de l\'application sous `vita/`. Les jeux installés sont dans `ux0/app`, le cache des shaders dans `cache`, et les patchs dans `patch`.</string>
    <string name="settings_about_title">À propos d\'EmuCoreV</string>
    <string name="settings_about_body">EmuCoreV est un émulateur PS Vita pour Android basé sur le projet open-source Vita3K.</string>
    <string name="settings_help_content_description">Ouvrir l\'aide des paramètres</string>
    <string name="settings_help_pstv_mode">Active le mode PlayStation TV pour les jeux qui l\'attendent.</string>
    <string name="settings_help_performance_overlay">Affiche les FPS et les statistiques de performance par-dessus le jeu.</string>
    <string name="settings_help_performance_overlay_detail">Définit la quantité de données affichées dans la superposition de performances.</string>
    <string name="settings_help_performance_overlay_position">Définit l\'endroit où la superposition de performances apparaît à l\'écran.</string>
    <string name="settings_help_stretch_display">Remplit une plus grande partie de l\'écran, mais peut étirer l\'image.</string>
    <string name="settings_help_fps_hack">Supprime la limite normale d\'images par seconde dans certains jeux. Cela peut améliorer la vitesse, mais peut perturber la synchronisation.</string>
    <string name="settings_help_vsync">Réduit les déchirures d\'écran, mais peut diminuer les performances dans certains jeux.</string>
    <string name="settings_help_high_accuracy">Peut corriger des problèmes graphiques, mais réduit généralement les performances.</string>
    <string name="settings_help_resolution">Des valeurs plus élevées rendent l\'image plus nette, mais utilisent plus de puissance GPU.</string>
    <string name="settings_help_renderer">Vulkan est généralement le meilleur choix. OpenGL peut aider sur les appareils avec un faible support Vulkan.</string>
    <string name="settings_help_screen_filter">Le filtre bilinéaire adoucit l\'image. Le filtre le plus proche garde des bords plus nets.</string>
    <string name="settings_help_anisotropic">Améliore la clarté des textures sous certains angles, mais peut coûter en performances.</string>
    <string name="settings_help_texture_cache">Conserve les textures en cache pour réduire le travail répété.</string>
    <string name="settings_help_async_pipeline">Compile les pipelines graphiques en arrière-plan pour réduire les saccades.</string>
    <string name="settings_help_shader_compilation_notice">S\'affiche lorsque de nouveaux shaders sont en cours de compilation.</string>
    <string name="settings_help_shader_caching_warn">Affiche un message dans un coin pendant la phase initiale de mise en cache des shaders au démarrage du jeu.</string>
    <string name="settings_help_disable_surface_sync">Peut améliorer la vitesse sur certains appareils, mais peut causer une instabilité.</string>
    <string name="settings_help_gamepad_overlay">Affiche les contrôles à l\'écran lorsque vous n\'utilisez pas de manette physique.</string>
    <string name="settings_help_touchpad_cursor">Affiche le curseur tactile pour les jeux qui utilisent l\'entrée tactile avant ou arrière.</string>
    <string name="settings_help_overlay_scale">Modifie la taille des contrôles à l\'écran.</string>
    <string name="settings_help_overlay_opacity">Modifie la transparence des contrôles à l\'écran.</string>
    <string name="settings_help_disable_motion">Désactive les commandes de mouvement de votre appareil.</string>
    <string name="settings_help_analog_multiplier">Modifie la sensibilité du stick analogique.</string>
    <string name="settings_help_audio_backend">Change le moteur de sortie audio.</string>
    <string name="settings_help_audio_volume">Ajuste le volume audio de l\'émulateur.</string>
    <string name="settings_help_ngs_enable">Garde l\'audio NGS Vita activé pour l\'audio normal des jeux.</string>
    <string name="settings_help_packages_folder">Choisissez le dossier utilisé pour les fichiers de paquets Vita locaux.</string>
